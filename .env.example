# Copy to backend/.env for local API (never commit real secrets).

# Inbox that receives contact form submissions
CONTACT_TO_EMAIL=ssvinesocial@gmail.com

# Gmail SMTP — use an App Password (Google Account → Security), not your normal login password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password

# CORS — comma-separated origins, or * (dev only)
CORS_ORIGINS=*
